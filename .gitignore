# ---- Python (test harness / drivers) ----
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.venv/
venv/

# ---- xv6 / RISC-V build artifacts ----
# Generated by `make` in xv6-riscv and in each lab's overlay build.
*.o
*.d
*.asm
*.sym
*.img
fs.img
# Built kernel ELF is named plain "kernel" inside a kernel/ dir; match at any depth
# (kernel/ itself is a source directory and must stay tracked).
**/kernel/kernel
**/mkfs/mkfs
**/user/usys.S
*.elf
.gdbinit

# Emacs / backup files (xv6 convention)
*~
\#*\#
.\#*

# Compiled container binary (lab7 build artifact)
**/lab7-containers/**/mycontainer

# ---- Editor / IDE ----
.vscode/
.idea/
*.swp
*.swo

# ---- OS cruft ----
.DS_Store
Thumbs.db
