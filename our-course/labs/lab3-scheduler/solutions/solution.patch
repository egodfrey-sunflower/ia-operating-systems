+#define NMLFQ 3        // number of queue levels
+#define MLFQ_BOOST 100 // priority-boost period, in ticks
+
+// Time slice (in ticks) for each level: doubles as you go down.
+static int
+mlfq_quantum(int lvl)
+{
+  static const int q[NMLFQ] = { 1, 2, 4 };
+  if (lvl < 0)
+    lvl = 0;
+  if (lvl >= NMLFQ)
+    lvl = NMLFQ - 1;
+  return q[lvl];
+}
