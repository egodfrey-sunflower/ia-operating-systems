+static uint64 rng_state = 0x2545F4914F6CDD1DULL;
+
+static uint
+rand_next(void)
+{
+  uint64 x = rng_state;
+  x ^= x << 13;
+  x ^= x >> 7;
+  x ^= x << 17;
+  rng_state = x;
+  return (uint)(x & 0x7fffffff);
+}
+#endif
