     memset((char *)r, 5, PGSIZE); // fill with junk
   return (void *)r;
 }
+
+// sysinfo(): return the amount of free physical memory, in bytes, by counting
+// the pages on the free list.
+uint64
+kfreemem(void)
+{
+  struct run *r;
+  uint64 npages = 0;
+
+  acquire(&kmem.lock);
+  for (r = kmem.freelist; r; r = r->next)
+    npages++;
+  release(&kmem.lock);
+
+  return npages * PGSIZE;
+}
