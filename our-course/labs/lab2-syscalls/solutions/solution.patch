diff -ruN a/kernel/sysproc.c b/kernel/sysproc.c
--- a/kernel/sysproc.c	2026-07-04 13:54:27.640391901 +0000
+++ b/kernel/sysproc.c	2026-07-04 13:54:27.728391943 +0000
@@ -6,6 +6,7 @@
 #include "spinlock.h"
 #include "proc.h"
 #include "vm.h"
+#include "sysinfo.h"
 
 uint64
 sys_exit(void)
@@ -107,3 +108,42 @@
   release(&tickslock);
   return xticks;
 }
+
+// trace(mask): record the syscall-trace bitmask for the calling process.
+// The mask is inherited by children (see kfork) and preserved across exec.
+uint64
+sys_trace(void)
+{
+  int mask;
+
+  argint(0, &mask);
+  myproc()->trace_mask = mask;
+  return 0;
+}
+
+// sysinfo(addr): fill a struct sysinfo at user address addr with the amount
+// of free physical memory and the number of in-use processes.
+uint64
+sys_sysinfo(void)
+{
+  uint64 addr;
+  struct sysinfo info;
+  struct proc *p = myproc();
+
+  argaddr(0, &addr);
+
+  info.freemem = kfreemem();
+  info.nproc = knproc();
+
+  if (copyout(p->pagetable, addr, (char *)&info, sizeof(info)) < 0)
+    return -1;
+  return 0;
+}
+
+// getppid(): return the pid of the calling process's parent, or 1 (init) if
+// the parent has exited and init adopted us.
+uint64
+sys_getppid(void)
+{
+  return kgetppid();
+}
