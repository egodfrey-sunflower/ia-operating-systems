+// sysinfo(): count processes whose state is not UNUSED.
+uint64
+knproc(void)
+{
+  struct proc *p;
+  uint64 n = 0;
+
+  for (p = proc; p < &proc[NPROC]; p++) {
+    acquire(&p->lock);
+    if (p->state != UNUSED)
+      n++;
+    release(&p->lock);
+  }
+  return n;
+}
+
+// getppid(): return the pid of the calling process's parent. wait_lock guards
+// p->parent, so that a concurrent kexit()/reparent() can't leave us reading a
+// half-updated pointer. If the parent has exited, reparent() will have set
+// p->parent to initproc, so we return init's pid.
+int
+kgetppid(void)
+{
+  struct proc *p = myproc();
+  int ppid;
+
+  acquire(&wait_lock);
+  if (p->parent)
+    ppid = p->parent->pid;
+  else
+    ppid = 0; // only init has no parent
+  release(&wait_lock);
+  return ppid;
+}
