@@ -387,6 +387,12 @@
 #define PTE_X (1L << 3)
 #define PTE_U (1L << 4) // user can access
 
+// Lab 4 Task 3: a copy-on-write marker kept in one of the two RSW
+// (reserved-for-software) bits of the PTE. The hardware ignores it; the
+// kernel uses it to recognise a page that must be privately copied on the
+// first store. It is preserved by PTE_FLAGS() (mask 0x3FF).
+#define PTE_COW (1L << 8)
+
 // shift a physical address to the right place for a PTE.
 #define PA2PTE(pa) ((((uint64)pa) >> 12) << 10)
 
