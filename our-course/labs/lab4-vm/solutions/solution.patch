+// Is the fault at va a copy-on-write fault? True iff va maps a valid,
+// user-accessible page that carries the PTE_COW marker.
+int
+iscowfault(pagetable_t pagetable, uint64 va)
+{
+  pte_t *pte;
+
+  if (va >= MAXVA)
+    return 0;
+  if ((pte = walk(pagetable, va, 0)) == 0)
+    return 0;
+  if ((*pte & PTE_V) == 0 || (*pte & PTE_U) == 0)
+    return 0;
+  return (*pte & PTE_COW) != 0;
+}
+
+// Break a copy-on-write page: give the faulting process its own private,
+// writable copy of the shared frame at va, and drop its reference to the
+// old shared frame. Returns the physical address of the now-writable page,
+// or 0 on failure (bad va or out of memory).
+uint64
+cowfault(pagetable_t pagetable, uint64 va)
+{
+  pte_t *pte;
+  uint64 pa;
+  uint flags;
+  char *mem;
+
+  if (va >= MAXVA)
+    return 0;
+  va = PGROUNDDOWN(va);
+  if ((pte = walk(pagetable, va, 0)) == 0)
+    return 0;
+  if ((*pte & PTE_V) == 0 || (*pte & PTE_COW) == 0)
+    return 0;
+
+  pa = PTE2PA(*pte);
+  flags = (PTE_FLAGS(*pte) & ~PTE_COW) | PTE_W;
+
+  if (krefcount((void *)pa) == 1) {
+    // We are the sole owner: no copy needed, just make it writable again.
+    *pte = PA2PTE(pa) | flags;
+    return pa;
+  }
+
+  if ((mem = kalloc()) == 0)
+    return 0;
+  memmove(mem, (char *)pa, PGSIZE);
+  *pte = PA2PTE((uint64)mem) | flags; // point PTE at the private copy
+  kfree((void *)pa);                  // drop our reference to the shared frame
+  return (uint64)mem;
+}
+
+// Print a page table as an indented tree (MIT 6.1810 format), for debugging.
+static void
+vmprintwalk(pagetable_t pagetable, int level)
+{
+  for (int i = 0; i < 512; i++) {
+    pte_t pte = pagetable[i];
+    if (pte & PTE_V) {
+      for (int j = 0; j < level; j++)
+        printk(" ..");
+      uint64 child = PTE2PA(pte);
+      printk("%d: pte %p pa %p\n", i, (void *)pte, (void *)child);
+      // If this PTE is not a leaf, descend into the next-level table.
+      if ((pte & (PTE_R | PTE_W | PTE_X)) == 0)
+        vmprintwalk((pagetable_t)child, level + 1);
+    }
+  }
+}
+
+void
+vmprint(pagetable_t pagetable)
+{
+  printk("page table %p\n", (void *)pagetable);
+  vmprintwalk(pagetable, 1);
+}
