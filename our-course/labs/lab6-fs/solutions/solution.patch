diff -ruN a/kernel/sysfile.c b/kernel/sysfile.c
--- a/kernel/sysfile.c	2026-07-05 13:58:26.677498855 +0000
+++ b/kernel/sysfile.c	2026-07-05 13:58:26.830498859 +0000
@@ -328,6 +328,32 @@
       return -1;
     }
     ilock(ip);
+    // Follow symbolic links (unless O_NOFOLLOW). A T_SYMLINK inode stores its
+    // target path as its file contents; resolve it, chasing chains, with a
+    // depth limit so a cycle is refused instead of looping forever.
+    int depth = 0;
+    while (ip->type == T_SYMLINK && !(omode & O_NOFOLLOW)) {
+      char target[MAXPATH];
+      int len;
+      if (++depth > 10) { // too many hops: probably a cycle
+        iunlockput(ip);
+        end_op();
+        return -1;
+      }
+      len = readi(ip, 0, (uint64)target, 0, MAXPATH - 1);
+      if (len <= 0) {
+        iunlockput(ip);
+        end_op();
+        return -1;
+      }
+      target[len] = 0;
+      iunlockput(ip); // done with the link inode
+      if ((ip = namei(target)) == 0) {
+        end_op(); // dangling link
+        return -1;
+      }
+      ilock(ip);
+    }
     if (ip->type == T_DIR && omode != O_RDONLY) {
       iunlockput(ip);
       end_op();
@@ -504,3 +530,33 @@
   }
   return 0;
 }
+
+// Create a symbolic link at `path` that points at `target`.
+// The target path is stored verbatim (no trailing NUL) as the link's
+// file contents; it need not exist (a dangling link is allowed).
+uint64
+sys_symlink(void)
+{
+  char target[MAXPATH], path[MAXPATH];
+  struct inode *ip;
+  int len;
+
+  if (argstr(0, target, MAXPATH) < 0 || argstr(1, path, MAXPATH) < 0)
+    return -1;
+
+  begin_op();
+  if ((ip = create(path, T_SYMLINK, 0, 0)) == 0) {
+    end_op();
+    return -1;
+  }
+  // create() returns ip locked; store the target path as its contents.
+  len = strlen(target);
+  if (writei(ip, 0, (uint64)target, 0, len) != len) {
+    iunlockput(ip);
+    end_op();
+    return -1;
+  }
+  iunlockput(ip);
+  end_op();
+  return 0;
+}
