+
+    // Load the singly-indirect (mid) block, allocating if necessary.
+    bp = bread(ip->dev, addr);
+    a = (uint *)bp->data;
+    if ((addr = a[idx1]) == 0) {
+      addr = balloc(ip->dev);
+      if (addr) {
+        a[idx1] = addr;
+        log_write(bp);
+      }
