def read_store(path):
    records = []
    with open(path) as f:
        for line in f:
            line = line.strip()
            if not line or line.startswith("#"):
                continue
            user, scheme, cost, salt_hex, hash_hex = line.split()
            salt = b"" if salt_hex == "-" else bytes.fromhex(salt_hex)
            records.append({"user": user, "scheme": scheme, "cost": int(cost),
                            "salt": salt, "hash": hash_hex})
    return records


def load_words(path):
    words = []
    with open(path) as f:
        for line in f:
            w = line.rstrip("\n")
            if w:
                words.append(w)
            if len(words) >= MAX_WORDS:
                sys.stderr.write("crack: wordlist capped at %d words\n" % MAX_WORDS)
                break
    return words


def main(argv):
    if len(argv) != 3:
        sys.stderr.write("usage: crack <storefile> <wordlist>\n")
        return 2
    records = read_store(argv[1])
    words = load_words(argv[2])
    W = len(words)

    cracked = {}        # user -> word
    hash_ops = 0
    t0 = time.perf_counter()

    # TODO (Part 1): mount the attack.
    #   - Split the records into unsalted and salted/slow.
    #   - Unsalted: build ONE digest->word table (W hashes), then look up each
    #     unsalted user.  hash_ops += W.
    #   - Salted/slow: for each such user, hash every word with THAT user's salt
    #     and cost; on a match, record cracked[user] = word.  hash_ops += W per
    #     user.  Do not early-exit, so the count stays deterministic.

    dt = time.perf_counter() - t0

    for user in sorted(cracked):
        print("cracked user=%s password=%s" % (user, cracked[user]))
    rate = (hash_ops / dt) if dt > 0 else 0.0
    print("crack recovered=%d users=%d words=%d hash_ops=%d seconds=%.4f rate=%.0f"
          % (len(cracked), len(records), W, hash_ops, dt, rate))
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv))
