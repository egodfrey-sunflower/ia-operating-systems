#!/usr/bin/env python3
# crashfs -- Lab 9 Part 2: the unjournaled allocating write.  STARTER.
#
#   crashfs mkfs <image>
#   crashfs workload <image> [crash=<k>]
#
# The workload is ONE unprotected create -- file "f", 2 data blocks, block j
# filled with xv6fs.fill_pattern(1, j) -- issued as exactly five block writes
# in the handout's fixed order:
#
#   W1  the root directory block   (the new entry f -> its inode)
#   W2  the inode block            (type T_FILE, nlink 1, size 2048, both addrs)
#   W3  the bitmap block           (both data blocks marked in use)
#   W4  data block 0
#   W5  data block 1
#
# The xv6fs helpers do the byte-level work; what you write here is the
# SEQUENCE -- the find_* steps read without writing, and each write_* step
# issues exactly one block write, so the order they appear below is the order
# the device sees.  Output contract (fixed): each issued write prints
# `issue <dirent|inode|bitmap|data> bno=<b>` BEFORE it is issued; completion
# prints `workload done installs=5`; a crash prints `CRASH installs=<k>` and
# exits 3 (main() below already handles that).

import os
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
