#!/usr/bin/env python3
# crashfs -- Lab 9 Part 2: the unjournaled allocating write.  REFERENCE.
#
#   crashfs mkfs <image>
#   crashfs workload <image> [crash=<k>]
#
# The workload is ONE unprotected create -- file "f", 2 data blocks, block j
# filled with byte 64 + 8*1 + j -- issued as exactly five block writes in the
# handout's fixed order:
#
#   W1  the root directory block   (the new entry f -> its inode)
#   W2  the inode block            (type, nlink 1, size 2048, both addrs)
#   W3  the bitmap block           (both data blocks marked in use)
#   W4  data block 0
#   W5  data block 1
#
# Each issued write prints `issue <what> bno=<b>`; completion prints
# `workload done installs=5`; a crash prints `CRASH installs=<k>` and exits 3.

import os
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import xv6fs                     # noqa: E402
import blockdev                  # noqa: E402


def workload(dev):
    ino = xv6fs.find_free_inode(dev)
    blocks = xv6fs.find_free_blocks(dev, 2)

    print("issue dirent bno=%d" % xv6fs.FIRSTDATA)
    xv6fs.dirent_add(dev, "f", ino)                          # W1

    dino = xv6fs.Dinode(type=xv6fs.T_FILE, nlink=1, size=2 * xv6fs.BSIZE)
    dino.addrs[0], dino.addrs[1] = blocks[0], blocks[1]
    print("issue inode bno=%d" % (xv6fs.INODESTART + ino // xv6fs.IPB))
    xv6fs.write_inode(dev, ino, dino)                        # W2

    print("issue bitmap bno=%d" % xv6fs.BMAPSTART)
    xv6fs.bitmap_mark(dev, blocks)                           # W3

    for j, b in enumerate(blocks):
        print("issue data bno=%d" % b)
        dev.write_data(b, xv6fs.fill_pattern(1, j))          # W4, W5


def main(argv):
    if len(argv) < 3:
        sys.stderr.write("usage: crashfs mkfs|workload <image> [crash=<k>]\n")
        return 2
    cmd, image, rest = argv[1], argv[2], argv[3:]

    if cmd == "mkfs":
        dev = blockdev.BlockDev(image, nblocks=xv6fs.FSSIZE)
        xv6fs.mkfs(dev)
        print("mkfs ok size=%d logstart=%d inodestart=%d bmapstart=%d firstdata=%d"
              % (xv6fs.FSSIZE, xv6fs.LOGSTART, xv6fs.INODESTART,
                 xv6fs.BMAPSTART, xv6fs.FIRSTDATA))
        return 0

    if cmd == "workload":
        crash = None
        for a in rest:
            if a.startswith("crash="):
                crash = int(a.split("=", 1)[1])
        dev = blockdev.BlockDev(image, crash_after=crash)
        try:
            workload(dev)
            print("workload done installs=%d" % dev.installs)
        except blockdev.Crash as c:
            print("CRASH installs=%s" % c.args[0])
            return 3
        return 0

    sys.stderr.write("crashfs: unknown command '%s'\n" % cmd)
    return 2


if __name__ == "__main__":
    sys.exit(main(sys.argv))
